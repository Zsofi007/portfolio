# VITE_PREVIEW_SHOWCASE_URL=https://showcase.example.com
# VITE_APP_SHOWCASE_URL=https://showcase.example.com
# VITE_REPO_SHOWCASE_URL=https://github.com/you/showcase
# VITE_PREVIEW_LAB_URL=https://lab.example.com
# VITE_APP_LAB_URL=https://lab.example.com
# VITE_REPO_LAB_URL=https://github.com/you/lab
# Optional PDF for Resume app download
# VITE_RESUME_URL=https://example.com/resume.pdf
